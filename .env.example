# ==============================================
# TradeLens Environment Configuration
# ==============================================
# Copy this file to .env and fill in your values

# --- Exchange Configuration ---
EXCHANGE_MODE=mock                    # mock | binance
BINANCE_API_KEY=your_api_key_here
BINANCE_SECRET_KEY=your_secret_here
BINANCE_WS_URL=wss://stream.binance.com:9443/ws

# --- Mock Exchange ---
MOCK_EXCHANGE_HOST=mock-exchange
MOCK_EXCHANGE_PORT=8765
MOCK_REPLAY_SPEED=10                  # 1x, 10x, 100x speed

# --- Redpanda ---
REDPANDA_BROKERS=redpanda:9092
REDPANDA_EXTERNAL_BROKERS=localhost:19092

# --- TimescaleDB ---
TIMESCALE_HOST=timescaledb
TIMESCALE_PORT=5432
TIMESCALE_USER=tradelens
TIMESCALE_PASSWORD=tradelens_secret
TIMESCALE_DB=market_data

# --- PostgreSQL (User/Order State) ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5433
POSTGRES_USER=tradelens
POSTGRES_PASSWORD=tradelens_secret
POSTGRES_DB=tradelens

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# --- API Gateway ---
GATEWAY_PORT=4000
JWT_SECRET=change-this-to-a-random-secret-in-production
JWT_EXPIRY=24h

# --- Backtester ---
BACKTESTER_HOST=backtester
BACKTESTER_PORT=8000

# --- Frontend ---
VITE_WS_URL=ws://localhost:4000/ws
VITE_API_URL=http://localhost:4000/api
